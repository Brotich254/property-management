# Database Configuration
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/property_management
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres

# JWT Secret
